function _add_to_path() {
    typeset -gU PATH
    for dir; do
        if [[ ! ":$PATH:" == *":$dir:"* ]]; then
            PATH="$dir:$PATH"
        fi
    done
}

local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"

_add_to_path "$HOME/.local/bin" "${config_dir}/cargo/bin"

unfunction _add_to_path

#!/usr/bin/env sh

if [ $# -ne 1 ]; then
    printf "%s\n" "Usage: regenerate-configuration CONFIG-NAME"
    exit 1
fi

config_name="$1"
target_file_name="dyn_config.json"
executable="$(chezmoi source-path)/_dynamic/configurator.py"


if [ ! -x "$executable" ]; then
    printf "%s\n" "Error: $executable is not executable"
    exit 1
fi

source_path="$(chezmoi source-path)/_dynamic/${config_name%%.json}.json"
target_path="$(chezmoi source-path)/_dynamic/$target_file_name"

"$executable" "$source_path" "$target_path"

#!/usr/bin/env sh

# crontab-ref show|edit|apply

filename=".crontab.age"

case "$1" in
  show)
    TMP="$(mktemp -t crontab)" || exit 1
    trap 'rm -f "$TMP"' EXIT INT TERM HUP

    chezmoi decrypt "$(chezmoi source-path)/.chezmoitemplates/$filename" > "$TMP"
    chezmoi execute-template -f "$TMP"
    ;;

  edit)
    TMP="$(mktemp -t crontab)" || exit 1
    trap 'rm -f "$TMP"' EXIT INT TERM HUP

    chezmoi decrypt "$(chezmoi source-path)/.chezmoitemplates/$filename" > "$TMP"
    ${EDITOR:-vi} "$TMP"
    chezmoi encrypt --output "$(chezmoi source-path)/.chezmoitemplates/$filename" "$TMP"
    printf "%s\n" "Template $filename re-encrypted. Commit & push when ready."
    ;;

  apply)
    crontab-ref show | crontab -
    printf "%s\n" "Crontab installed from rendered template."
    ;;

  *)
    printf "%s\n" "Usage: crontab-ref show|edit|apply"
    ;;
esac

#!/usr/bin/env sh

# edit-encrypted-template <encrypted_template_file_name in .chezmoitemplates>
# edit-encrypted-template list  # lists available .age files in .chezmoitemplates

file_name="$1"
templates_dir="$(chezmoi source-path)/.chezmoitemplates"


if [ "$file_name" = "list" ]; then
    find "$templates_dir" -maxdepth 1 -name "*.age" -printf "%f\n" | sort
    exit 0

else
    encrypted_template_path="$templates_dir/$file_name"

    TMP="$(mktemp -t edit-encrypted.XXXX)" || exit 1
    CHECKSUM="$TMP.checksum"
    trap 'rm -f "$TMP" "$CHECKSUM"' EXIT INT TERM HUP

    chezmoi decrypt "$encrypted_template_path" > "$TMP"
    sha512sum --tag "$TMP" > "$CHECKSUM"

    ${EDITOR:-vi} "$TMP"

    if ! sha512sum --check --status "$CHECKSUM"; then
        chezmoi encrypt --output "$encrypted_template_path" "$TMP"
        printf "%s\n" "Template $file_name re-encrypted. Commit & push when ready."
    fi
fi

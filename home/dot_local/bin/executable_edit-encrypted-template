#!/usr/bin/env sh

file_name="$1"

if [ -z "$file_name" ]; then
    printf "%s\n" "Usage help:"

    printf "%s\n" "List available templates:"
    printf "%s\n" "edit-encrypted-template list"

    printf "%s\n" "Edit a template"
    printf "%s\n" "edit-encrypted-template <template_name>"

    exit 1
fi

templates_dir="$(chezmoi source-path)/.chezmoitemplates"


if [ "$file_name" = "list" ]; then
    find "$templates_dir" -maxdepth 1 -name "*.age" -printf "%f\n" | sort
    exit 0

else
    encrypted_template_path="$templates_dir/$file_name"

    temp_file="$(mktemp -t edit-encrypted.XXXX)" || exit 1
    checksum_file="$temp_file.checksum"
    trap 'rm -f "$temp_file" "$checksum_file"' EXIT INT TERM HUP

    chezmoi decrypt "$encrypted_template_path" > "$temp_file"
    sha512sum --tag "$temp_file" > "$checksum_file"

    ${EDITOR:-vi} "$temp_file"

    if ! sha512sum --check --status "$checksum_file"; then
        chezmoi encrypt --output "$encrypted_template_path" "$temp_file"
        printf "%s\n" "Template $file_name re-encrypted. Commit & push when ready."
    fi
fi
